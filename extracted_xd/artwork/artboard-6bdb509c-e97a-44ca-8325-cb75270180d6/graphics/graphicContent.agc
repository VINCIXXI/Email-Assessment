":264,"to":298,"x":0,"style":{"font":{"postscriptName":"NewTransportAA-Light","family":"New Transport AA","style":"Light"}}}]]}],"rawText":"On average, five people a day are killed on our roads and 82 are seriously injured. We’ve looked at 9 ways to reduce this – including reintroducing road safety targets, maintaining driver training and increasing road traffic officers – because road death needs to be higher on the political agenda."}},{"type":"text","name":"Saving lives","meta":{"ux":{"nameL10N":"SHAPE_GROUP","constraintLeft":true,"constraintWidth":true,"constraintHeight":true,"singleTextObject":true,"rangedStyles":[{"length":42,"linkId":"","fontFamily":"AA Sans","fontStyle":"Black","postscriptName":"AA-Sans-Black","fontSize":18,"charSpacing":5,"underline":false,"textTransform":"none","textScript":"none","fill":{"value":4278192156},"strikethrough":false,"hyperlinkUrl":""}],"localTransform":{"a":1,"b":0,"c":0,"d":1,"tx":59.5,"ty":1322.943359375}}},"id":"1813eb56-a3e8-4986-a3dd-4caaf8dbf271","transform":{"a":1,"b":0,"c":0,"d":1,"tx":-10424.5,"ty":4938.943359375},"style":{"fill":{"type":"solid","color":{"mode":"RGB","value":{"r":0,"g":8,"b":28}}},"font":{"postscriptName":"AA-Sans-Black","family":"AA Sans","style":"Black","size":18},"textAttributes":{"letterSpacing":5,"lineHeight":19,"paragraphAfterSpacing":18}},"text":{"frame":{"type":"area","width":234.5,"height":28.6513671875},"paragraphs":[{"lines":[[{"y":12,"from":0,"to":12,"x":0}]]}],"rawText":"Saving lives"}},{"type":"text","name":"Read the full manifesto for a comprehensive look at all the topics on our agenda – including driving a sustainable future and how we’re strengthening the industry.","meta":{"ux":{"nameL10N":"SHAPE_GROUP","constraintLeft":true,"constraintRight":true,"constraintHeight":true,"singleTextObject":true,"rangedStyles":[{"length":163,"linkId":"","fontFamily":"New Transport AA","fontStyle":"Bold","postscriptName":"NewTransportAA-Bold","fontSize":18,"charSpacing":5,"underline":false,"textTrans