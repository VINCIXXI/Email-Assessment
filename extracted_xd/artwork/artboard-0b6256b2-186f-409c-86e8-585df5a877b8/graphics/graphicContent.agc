ight":true,"constraintHeight":true,"singleTextObject":true,"rangedStyles":[{"length":181,"linkId":"","fontFamily":"New Transport AA","fontStyle":"Regular","postscriptName":"NewTransportAA-Regular","fontSize":14,"charSpacing":0,"underline":false,"textTransform":"none","textScript":"none","fill":{"value":4278192156},"strikethrough":false,"hyperlinkUrl":""}],"localTransform":{"a":1,"b":0,"c":0,"d":1,"tx":30,"ty":1878.02099609375}}},"id":"e962c3c7-3d7a-49c6-81c6-806e0725c003","transform":{"a":1,"b":0,"c":0,"d":1,"tx":-9409,"ty":5494.02099609375},"style":{"fill":{"type":"solid","color":{"mode":"RGB","value":{"r":0,"g":8,"b":28}}},"font":{"postscriptName":"NewTransportAA-Regular","family":"New Transport AA","style":"Regular","size":14},"textAttributes":{"lineHeight":18,"paragraphAfterSpacing":10}},"text":{"frame":{"type":"area","width":300,"height":129.302734375},"paragraphs":[{"lines":[[{"y":14,"from":0,"to":48,"x":0,"style":{"font":{"postscriptName":"NewTransportAA-Light","family":"New Transport AA","style":"Light"}}}],[{"y":32,"from":48,"to":97,"x":0,"style":{"font":{"postscriptName":"NewTransportAA-Light","family":"New Transport AA","style":"Light"}}}],[{"y":50,"from":97,"to":134,"x":0,"style":{"font":{"postscriptName":"NewTransportAA-Light","family":"New Transport AA","style":"Light"}}}],[{"y":68,"from":134,"to":181,"x":0,"style":{"font":{"postscriptName":"NewTransportAA-Light","family":"New Transport AA","style":"Light"}}}],[{"y":86,"from":181,"to":234,"x":0,"style":{"font":{"postscriptName":"NewTransportAA-Light","family":"New Transport AA","style":"Light"}}}],[{"y":104,"from":234,"to":281,"x":0,"style":{"font":{"postscriptName":"NewTransportAA-Light","family":"New Transport AA","style":"Light"}}}],[{"y":122,"from":281,"to":298,"x":0,"style":{"font":{"postscriptName":"NewTransportAA-Light","family":"New Transport AA","style":"Light"}}}]]}],"rawText":"On average, five people a day are killed on our roads and 82 are seriously injured. We’ve looked at 9 ways to reduce this – including reintroducing road safety targets, maintaining driver training and increasing road traffic officers – because road death needs to be higher on the political agenda."}},{"type":"text","name":"With a larger member base, we could have a bigger influence on government decisions. Invite your friends to take out breakdown cover with us and when they join, you’ll both get a £30 M&S or  Amazon.co.uk gift card1. Offer ends 23 May 2024.","meta":{"ux":{"nameL10N":"SHAPE_GROUP","constraintLeft":true,"constraintRight":true,"constraintHeight":true,"singleTextObject":true,"rangedStyles":[{"length":213,"linkId":"","fontFamily":"New Transport AA","fontStyle":"Regular","postscriptName":"NewTransportAA-Regular","fontSize":14,"charSpacing":0,"underline":false,"textTransform":"none","textScript":"none","fill":{"value":4278192156},"strikethrough":false,"hyperlinkUrl":""},{"length":1,"linkId":"","fontFamily":"New Transport AA","fontStyle":"Regular","postscriptName":"NewTransportAA-Regular","fontSize":14,"charSpacing":0,"underline":false,"textTransform":"none","textScript":"superscript","fill":{"value":4278192156},"strikethrough":false,"hyperlinkUrl":""},{"length":1,"linkId":"","fontFamily":"New Transport AA","fontStyle":"Regular","postscriptName":"NewTransportAA-Regular","fontSize":14,"charSpacing":0,"underline":false,"textTransform":"none","textScript":"none","fill":{"value":4278192156},"strikethrough":false,"hyperlinkUrl":""}],"localTransform":{"a":1,"b":0,"c":0,"d":1,"tx":30,"ty":2421.71630859375}}},"id":"31ccdc58-8a16-4dc2-ade9-bac9c867a2b5","transform":{"a":1,"b":0,"c":0,"d":1,"tx":-9409,"ty":6037.71630859375},"style":{"fill":{"type":"solid","color":{"mode":"RGB","value":{"r":0,"g":8,"b":28}}},"font":{"postscriptName":"NewTransportAA-Regular","family":"New Transport AA","style":"Regular","size":14},"textAttributes":{"lineHeight":18,"paragraphAfterSpacing":10}},"text":{"frame":{"type":"area","width":300,"height":109.62451171875},"paragraphs":[{"lines":[[{"y":14,"from