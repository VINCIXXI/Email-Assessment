"New Transport AA","style":"Light"}}}],[{"y":160,"from":312,"to":353,"x":0,"style":{"font":{"postscriptName":"NewTransportAA-Light","family":"New Transport AA","style":"Light"}}}],[{"y":178,"from":353,"to":407,"x":0,"style":{"font":{"postscriptName":"NewTransportAA-Light","family":"New Transport AA","style":"Light"}}}]]}],"rawText":"Hello <First name>,\nAt The AA, nothing matters more to us than motorists. So we’ve spoken to a panel of members like you about what’s important to them. And we’ve brought that insight together in a manifesto for government, journalists and civil servants.\nWe’re calling on all political parties to listen to the needs of drivers, and take action on our recommendations to help shape a better road ahead for all motorists.\n"}},{"type":"text","name":"Read the full manifesto for a comprehensive look at all the topics on our agenda – including driving a sustainable future and how we’re strengthening the industry.","meta":{"ux":{"nameL10N":"SHAPE_GROUP","constraintLeft":true,"constraintRight":true,"constraintHeight":true,"singleTextObject":true,"rangedStyles":[{"length":163,"linkId":"","fontFamily":"New Transport AA","fontStyle":"Bold","postscriptName":"NewTransportAA-Bold","fontSize":18,"charSpacing":5,"underline":false,"textTransform":"none","textScript":"none","fill":{"value":4278192156},"strikethrough":false,"hyperlinkUrl":""}],"localTransform":{"a":1,"b":0,"c":0,"d":1,"tx":14,"ty":2056.388671875}}},"id":"4f06f52c-946c-411d-b6eb-1c08b092a779","transform":{"a":1,"b":0,"c":0,"d":1,"tx":-9425,"ty":5672.388671875},"style":{"fill":{"type":"solid","color":{"mode":"RGB","value":{"r":0,"g":8,"b":28}}},"font":{"postscriptName":"NewTransportAA-Bold","family":"New Transport AA","style":"Bold","size":18},"textAttributes":{"letterSpacing":5,"lineHeight":19,"paragraphAfterSpacing":18}},"text":{"frame":{"type":"area","width":336,"height":106.19775390625},"paragraphs":[{"lines":[[{"y":18,"from":0,"to":30,"x":0}],[{"y":37,"from":30,"to":70,"x":0}],[{"y":56